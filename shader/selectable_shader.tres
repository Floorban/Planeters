[gd_resource type="Shader" format=3 uid="uid://benyoh88f818t"]

[resource]
code = "shader_type canvas_item;

// --- TINT & VISIBILITY ---
// Use this to change the sprite color/alpha via code or inspector
uniform vec4 main_color : source_color = vec4(1.0);

// --- TOGGLES ---
uniform bool enable_shadow = false;
// 0: None, 1: Simple, 2: Progress (Ghosting + Fill Outline)
uniform int outline_mode : hint_enum(\"None\", \"Simple\", \"Progress\") = 0;

// --- SETTINGS ---
uniform vec4 outline_color : source_color = vec4(1.0);
uniform float outline_width : hint_range(0.0, 10.0) = 1.0;
uniform float shadow_dist = 2.0;
uniform vec4 shadow_color : source_color = vec4(0.0, 0.0, 0.0, 0.5);
uniform float shadow_angle : hint_range(0.0, 360.0) = 45.0;

// --- PROGRESS & GHOSTING ---
uniform float progress : hint_range(0.0, 1.0) = 1.0;
uniform float pending_alpha : hint_range(0.0, 1.0) = 0.3;
uniform int fill_style : hint_enum(\"Clock\", \"Center Fill\", \"Bottom Fill\") = 2;

// --- CALIBRATION ---
uniform float fill_start : hint_range(-10.0, 10.0) = 0.0; 
uniform float fill_end : hint_range(-10.0, 10.0) = 1.0;

varying vec2 local_uv;

void vertex() {
	// Stable UVs for Sprite Sheets
	local_uv = sign(VERTEX) * 0.5 + 0.5;
}

void fragment() {
	// Sample texture
	vec4 tex_color = texture(TEXTURE, UV);
	vec2 p_size = TEXTURE_PIXEL_SIZE;
	
	// 1. Calculate Fill Mask
	float fill = 1.0;
	// Always calculate fill logic so shadow and outline can use it
	switch (fill_style) {
		case 0: fill = step((atan(local_uv.x - 0.5, local_uv.y - 0.5) + PI) / 6.283185, progress); break;
		case 1: fill = step(distance(local_uv, vec2(0.5)), progress * 0.5); break;
		case 2: fill = step(1.0 - local_uv.y, mix(fill_start, fill_end, progress)); break;
	}

	// 2. Apply Ghosting to Texture (Only in mode 2)
	if (outline_mode == 2) {
		tex_color.a *= mix(pending_alpha, 1.0, fill);
	}

	// 3. Outline Logic
	vec4 final_outline = vec4(0.0);
	if (outline_mode != 0) {
		vec2 size = p_size * outline_width;
		// Check neighbors
		float a = texture(TEXTURE, UV + vec2(0.0, -size.y)).a;
		a = max(a, texture(TEXTURE, UV + vec2(0.0, size.y)).a);
		a = max(a, texture(TEXTURE, UV + vec2(-size.x, 0.0)).a);
		a = max(a, texture(TEXTURE, UV + vec2(size.x, 0.0)).a);
		
		float outline_mask = clamp(a - texture(TEXTURE, UV).a, 0.0, 1.0);
		
		if (outline_mode == 1) { // Simple
			final_outline = vec4(outline_color.rgb, outline_mask * outline_color.a);
		} else if (outline_mode == 2) { // Progress (Outline grows with fill)
			final_outline = vec4(outline_color.rgb, outline_mask * outline_color.a * fill);
		}
	}

	// 4. Drop Shadow Logic
	vec4 final_shadow = vec4(0.0);
	if (enable_shadow) {
		float rad = radians(shadow_angle);
		vec2 shadow_offset = vec2(cos(rad), sin(rad)) * p_size * shadow_dist;
		float shadow_alpha = texture(TEXTURE, UV - shadow_offset).a;
		// Shadow respects progress ghosting
		if (outline_mode == 2) {
			shadow_alpha *= mix(pending_alpha, 1.0, fill);
		}
		final_shadow = vec4(shadow_color.rgb, shadow_alpha * shadow_color.a);
	}

	// 5. Final Layering (Manual Alpha Blending)
	// Start with empty canvas
	vec4 combined = vec4(0.0);
	// Place Shadow
	combined = mix(combined, final_shadow, final_shadow.a);
	// Place Outline
	combined = mix(combined, final_outline, final_outline.a);
	// Place Sprite
	combined = mix(combined, tex_color, tex_color.a);
	
	// 6. APPLY COLORS
	// combined: The pixels we calculated
	// main_color: Your custom uniform color picker
	// COLOR: Built-in modulate (for inspector alpha/visibility)
	COLOR = combined * main_color * COLOR;
}"
